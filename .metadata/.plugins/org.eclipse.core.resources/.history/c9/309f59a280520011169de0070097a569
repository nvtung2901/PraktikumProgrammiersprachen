#include <iostream>
#include <string>

int main()
{
    int iErste = 0;
    int iZweite = 0;
    
    // Hier folgt Ihr eigener Code
    // Input
    std::cout << "Erste ganze Zahl: ";
    std::cin >> iErste;
    std::cout << "Zweite ganze Zahl:";
    std::cin >> iZweite;
    // Rechnen und Output
    int iQuotient = iErste/iZweite;
    std::cout << "Die Division " << iErste << "/" << iZweite
    		  << " ergibt die ganze Zahl: " << iQuotient << std::endl;
    return 0;
    
}
